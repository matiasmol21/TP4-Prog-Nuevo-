generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model producto {
  id        Int      @id @default(autoincrement())
  nombre    String
  precio    Float
  stock     Int
  categoria String
  createdAt DateTime @default(now())
  imagen    String?  @db.VarChar(500)
}
